@page "/"

<PageTitle>Home</PageTitle>

<section class="pagina-inicial">
    <section class="secao-banner">
        <div class="banner-principal">
            <p class="subtitulo-banner">Portifolio do Marcus</p>
            <h1 class="titulo-banner">Bem-vindo ao meu Portifolio</h1>
            <p class="texto-banner">
                Aqui voce encontra um resumo da minha vida/historia, do meu curriculo e das formas de contato.
            </p>
        </div>
    </section>

    <section class="secao-destaques" id="destaques" aria-label="Destaques do site">
        <article class="cartao-destaque cartao-claro">
            <span class="numero-destaque">01</span>
            <h2>Minha história</h2>
            <p>Minha História resumida de forma curta e simples.</p>
            <a href="/historia">Conhecer percurso</a>
        </article>

        <article class="cartao-destaque cartao-escuro">
            <span class="numero-destaque">02</span>
            <h2>Meu curriculo</h2>
            <p>Experiências e competências.</p>
            <a href="/curriculo">Ver experiencias</a>
        </article>

        <article class="cartao-destaque cartao-destaque-contato" id="contato">
            <span class="numero-destaque">03</span>
            <h2>Entre em contato</h2>
            <p>Meu e-mail e meu telefone.</p>
            <a href="/contato">Iniciar conversa</a>
        </article>
    </section>
</section>